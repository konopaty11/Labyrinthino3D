MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 93990ebb93c4cbe429f177f02b7f3323, type: 3}
  m_Name: DialogConfig
  m_EditorClassIdentifier: 
  logs:
  - author: 1
    name: "\u0418\u0433\u0440\u043E\u043A"
    message: "\u0413\u0434\u0435 \u044F? \u0422\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E
      \u0431\u044B\u043B \u043D\u0430 \u0437\u0430\u0441\u0442\u0430\u0432\u043A\u0435\u2026
      \u042D\u0442\u043E \u0441\u043E\u043D?"
  - author: 2
    name: ???
    message: "\u041F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E,
      \u0418\u0433\u0440\u043E\u043A! \u041D\u0438\u043A\u0430\u043A\u043E\u0439
      \u043D\u0435 \u0441\u043E\u043D, \u0430 \u0441\u0430\u043C\u043E\u0435 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0435
      \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0435. \u0414\u043E\u0431\u0440\u043E
      \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C \u0432 \u041B\u0430\u0431\u0438\u0440\u0438\u043D\u0442\u0438\u043D\u043E
      3D!\u201D."
  - author: 1
    name: "\u0418\u0433\u0440\u043E\u043A"
    message: "\u0422\u044B \u0440\u043E\u0431\u043E\u0442? \u0410 \u043A\u0430\u043A
      \u0442\u0435\u0431\u044F \u0437\u043E\u0432\u0443\u0442?"
  - author: 2
    name: "\u041B\u0430\u0431\u0438"
    message: "\u041C\u0435\u043D\u044F \u0437\u043E\u0432\u0443\u0442 \u041B\u0430\u0431\u0438!
      \u042F \u0442\u0432\u043E\u0439 \u043F\u0440\u043E\u0432\u043E\u0434\u043D\u0438\u043A
      \u0432 \u043C\u0438\u0440\u0435 \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043E\u043A.
      \u0417\u0434\u0435\u0441\u044C \u0442\u0435\u0431\u044F \u0436\u0434\u0443\u0442
      \u0447\u0435\u0442\u044B\u0440\u0435 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0445
      \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F: \u0432\u043E\u0434\u043D\u044B\u0435
      \u043A\u043E\u043C\u043D\u0430\u0442\u044B, \u043F\u0440\u044B\u0436\u043A\u0438
      \u043F\u043E \u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u0430\u043C,
      \u043B\u0430\u0437\u0435\u0440\u043D\u044B\u0435 \u043B\u0430\u0431\u0438\u0440\u0438\u043D\u0442\u044B
      \u0438 \u0434\u0430\u0436\u0435 \u0431\u0430\u0441\u043A\u0435\u0442\u0431\u043E\u043B
      \u0441 \u0445\u0438\u0442\u0440\u044B\u043C\u0438 \u0440\u044B\u0447\u0430\u0433\u0430\u043C\u0438!"
  - author: 1
    name: "\u0418\u0433\u0440\u043E\u043A"
    message: "\u0417\u0432\u0443\u0447\u0438\u0442 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u043E.
      \u0410 \u0435\u0441\u043B\u0438 \u044F \u0437\u0430\u043F\u0443\u0442\u0430\u044E\u0441\u044C?"
  - author: 2
    name: "\u041B\u0430\u0431\u0438"
    message: "\u0422\u043E\u0433\u0434\u0430 \u043F\u0440\u0438\u0434\u0451\u0442\u0441\u044F
      \u0432\u043A\u043B\u044E\u0447\u0438\u0442\u044C \u0441\u043C\u0435\u043A\u0430\u043B\u043A\u0443!
      \u041D\u043E \u044F \u0443\u0432\u0435\u0440\u0435\u043D: \u0442\u044B \u0441\u043F\u0440\u0430\u0432\u0438\u0448\u044C\u0441\u044F.
      \u0413\u043E\u0442\u043E\u0432 \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C,
      \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0442\u044B \u043D\u0430\u0445\u043E\u0434\u0447\u0438\u0432?"
  - author: 1
    name: "\u0418\u0433\u0440\u043E\u043A"
    message: "\u041B\u0435\u0433\u043A\u043E! \u041F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0439,
      \u0441 \u0447\u0435\u0433\u043E \u043D\u0430\u0447\u0430\u0442\u044C!"
