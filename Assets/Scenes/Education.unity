  m_Script: {fileID: 11500000, guid: 0ab6d3de658b4d847a0e65c3476a2131, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  tasks:
  - task: {fileID: 77084999}
    description: "\u0417\u0430\u0436\u043C\u0438\u0442\u0435 \u043B\u0435\u0432\u044B\u0439
      \u0434\u0436\u043E\u0439\u0441\u0442\u0438\u043A \u0438 \u043E\u0442\u043A\u043B\u043E\u043D\u044F\u0439\u0442\u0435
      \u0435\u0433\u043E, \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F"
  - task: {fileID: 2131656806}
    description: "\u0417\u0430\u0436\u043C\u0438\u0442\u0435 \u043F\u0440\u0430\u0432\u044B\u0439
      \u0434\u0436\u043E\u0439\u0441\u0442\u0438\u043A \u0438 \u043E\u0442\u043A\u043B\u043E\u043D\u044F\u0439\u0442\u0435
      \u0435\u0433\u043E, \u0447\u0442\u043E\u0431\u044B \u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C\u0441\u044F"
  - task: {fileID: 1849193076}
    description: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
      \u043F\u0440\u044B\u0436\u043A\u0430 (\u043D\u0430\u0434 \u043F\u0440\u0430\u0432\u044B\u043C
      \u0434\u0436\u043E\u0439\u0441\u0442\u0438\u043A\u043E\u043C) \u0447\u0442\u043E\u0431\u044B
      \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u043F\u0440\u044B\u0436\u043E\u043A"
  - task: {fileID: 1529957405}
    description: "\u041F\u043E\u0434\u043E\u0439\u0434\u0438\u0442\u0435 \u043A \u0434\u0432\u0435\u0440\u0438
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
      \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
      (\u043D\u0430\u0434 \u043A\u043D\u043E\u043F\u043A\u043E\u0439 \u043F\u0440\u044B\u0436\u043A\u0430)
      \u0447\u0442\u043E\u0431\u044B \u0432\u043E\u0439\u0442\u0438 \u0432 \u0434\u0432\u0435\u0440\u044C"
  taskLabel: {fileID: 433227612}
